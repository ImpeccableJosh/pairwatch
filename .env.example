# Pick one provider. Set PAIRWATCH_PROVIDER and fill in that provider's keys.
# Default is anthropic.
PAIRWATCH_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# PAIRWATCH_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Gemini ---
GEMINI_API_KEY=
# PAIRWATCH_GEMINI_MODEL=gemini-2.5-flash

# --- Cloudflare Workers AI ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# PAIRWATCH_CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
